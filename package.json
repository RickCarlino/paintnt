{
  "name": "paintnt",
  "version": "0.2.0",
  "description": "Paintn't: a tiny headless paint-style graphics library for TypeScript.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "assets",
    "CHANGELOG.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "browser-test:build": "bun ./scripts/browser-test.ts build",
    "browser-test:serve": "bun ./scripts/browser-test.ts serve",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "bun run build",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/node": "^24.11.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "bitmap",
    "bmp",
    "browser",
    "graphics",
    "node",
    "paint",
    "typescript"
  ],
  "license": "MIT"
}
